# Neon MCP connection
NEON_API_KEY=
NEON_PROJECT_ID=
NEON_DATABASE=
NEON_BRANCH_ID=

# Optional: override the default Neon MCP endpoint
# NEON_MCP_URL=https://mcp.neon.tech/mcp

# Gemini model (local dev)
# Option A: Google AI Studio (simplest)
GOOGLE_API_KEY=

# Option B: Vertex AI (requires gcloud auth application-default login)
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional: override the default model
# GEMINI_MODEL_ID=gemini-2.5-flash

# Architecture mode: "direct" (default, single-service) or "a2a" (multi-service)
# DATABASE_MODE=direct

# API key authentication (leave empty to disable)
# API_KEY=

# Rate limiting (slowapi format)
# RATE_LIMIT=30/minute

# CORS origins (comma-separated)
# ALLOWED_ORIGINS=*

# Persistence backend: "memory" (default) or "postgres"
# STORE_BACKEND=memory
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Agent URLs (defaults shown)
# DATABASE_AGENT_URL=http://localhost:8001/
# ORCHESTRATOR_PORT=8000
# DATABASE_AGENT_PORT=8001

# Frontend CORS (comma-separated origins, default: *)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
